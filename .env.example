# DuckDB 数据库路径
YGGDRASIL_DUCKDB_PATH=data/yggdrasil.duckdb

# ChromaDB 向量存储路径
YGGDRASIL_CHROMA_PATH=data/chroma

# 日志
YGGDRASIL_LOG_LEVEL=INFO
YGGDRASIL_LOG_FILE=logs/yggdrasil.log

# 应用
YGGDRASIL_HOST=0.0.0.0
YGGDRASIL_PORT=6061
YGGDRASIL_DEBUG=false

# LLM 嵌入配置
YGGDRASIL_LLM_PROVIDER=openai
YGGDRASIL_LLM_BASE_URL=https://api.openai.com/v1
YGGDRASIL_LLM_API_KEY=your-api-key
YGGDRASIL_LLM_MODEL=text-embedding-3-small
YGGDRASIL_LLM_EMBEDDING_DIM=1536

# 检索配置
YGGDRASIL_RETRIEVAL_MAX_NODES=50
YGGDRASIL_RETRIEVAL_MAX_DEPTH=2
YGGDRASIL_RETRIEVAL_STRENGTH_THRESHOLD=0.2

# 进化配置
YGGDRASIL_EVOLUTION_STEP_STRENGTH=0.1
YGGDRASIL_EVOLUTION_DECAY_FACTOR=0.95
YGGDRASIL_EVOLUTION_POLLUTION_THRESHOLD=0.3

# 巡检配置（cron，UTC）
YGGDRASIL_INSPECTION_CRON="0 0 * * *"